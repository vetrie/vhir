{
  "$schema": "https://json-schema.org/draft/2020-12",
  "$id": "https://vhir.dev/schemas/device.json",
  "title": "Device",
  "description": "Microchip, ear tag, leg band, wearable, or in-clinic monitor associated with an animal.",
  "type": "object",
  "required": ["resourceType", "type"],
  "properties": {
    "resourceType": { "const": "Device" },
    "id": { "type": "string" },
    "meta": { "$ref": "common.json#/$defs/Meta" },
    "type": {
      "type": "string",
      "enum": ["microchip-iso", "microchip-legacy-125khz", "microchip-legacy-128khz",
               "usda-840-eid", "ear-tag", "leg-band", "wearable", "in-clinic-monitor", "other"]
    },
    "status": { "type": "string", "enum": ["active", "inactive", "unknown"], "default": "active" },
    "identifiers": {
      "type": "array",
      "items": { "$ref": "common.json#/$defs/Identifier" }
    },
    "subject": { "$ref": "common.json#/$defs/Reference" },
    "owner": { "$ref": "common.json#/$defs/Reference" },
    "manufacturer": { "type": "string" },
    "model": { "type": "string" },
    "serialNumber": { "type": "string" },
    "lotNumber": { "type": "string" },
    "manufactureDate": { "type": "string", "format": "date" },
    "expirationDate": { "type": "string", "format": "date" },
    "udi": {
      "type": "string",
      "description": "Unique device identifier — for ISO 11784 chips this is the 15-digit decimal chip ID."
    },
    "note": { "type": "string" },
    "extensions": { "type": "object" }
  }
}
